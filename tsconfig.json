{
	"include": ["./src/**/*.ts", "./shared/**/*.ts", "app/src/util/toast.ts"],
	"compilerOptions": {
		"target": "es2022",
		"module": "commonjs",
		"resolveJsonModule": true,
		"outDir": "./dist/",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	}
}
